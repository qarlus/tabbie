{
  "manifest_version": 3,
  "name": "CapTab — Local-first New Tab",
  "short_name": "CapTab",
  "version": "0.4.0",
  "description": "A calm, local-first new tab — Capbar’s tab sibling. Your data stays in this browser.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "favicon",
    "storage",
    "tabs"
  ],
  "optional_permissions": [
    "bookmarks",
    "history",
    "topSites",
    "sessions",
    "downloads",
    "clipboardRead"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to CapTab",
    "default_icon": {
      "32": "icon-32.png",
      "128": "icon-128.png"
    }
  },
  "host_permissions": [
    "https://api.github.com/*",
    "https://api.linear.app/*",
    "https://api.todoist.com/*",
    "https://api.trello.com/*",
    "https://app.asana.com/*",
    "https://tasks.googleapis.com/*",
    "https://www.google.com/*",
    "https://icons.duckduckgo.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "icons": {
    "32": "icon-32.png",
    "128": "icon-128.png",
    "512": "icon-512.png"
  }
}
